---
import Icon from "./Icon.astro";
import { SITE } from "../config";

// Only render icons for networks that have a URL set in src/config.ts.
const socialLinks = ([
    { name: "instagram", label: "Instagram icon", url: SITE.social.instagram },
    { name: "threads", label: "Threads icon", url: SITE.social.threads },
    { name: "mastodon", label: "Mastodon icon", url: SITE.social.mastodon },
] as const).filter((link) => link.url);
---

<footer class="set-base-layout-max-width">
    <div class="flex-center flex-column">
        <p class="text-align-center">A website by {SITE.author}.</p><p class="text-align-center">
            © {SITE.startYear} - {new Date().getFullYear()}
        </p>
    </div>
    {socialLinks.length > 0 && (
        <ul role="list" class="flex-center">
            {socialLinks.map((link) => (
                <li>
                    <a href={link.url} target="_blank" rel="noopener noreferrer">
                        <Icon name={link.name} label={link.label} size="1.5rem" />
                    </a>
                </li>
            ))}
        </ul>
    )}
    <ul role="list" class="flex-center navigation-container">
        <li><p><a href="/">Home</a></p></li>
        <li><p><a href="/privacy">Privacy</a></p></li>
        <li><p><a href="/about">About</a></p></li>
        <li><p><a href="/about#contact">Contact</a></p></li>
        <li><p><a href="/sitemap-index.xml">Sitemap</a></p></li>
    </ul>
</footer>

<style>
    footer {
        display: grid;
        grid-template-columns: 1fr;
        min-height: var(--footer-height);
        align-items: center;
        margin-inline: auto;
        border-top: 1px solid var(--color-border);
        >* {
            height: max-content;
            margin-block: var(--space-s);
        }
    }
    ul {
        gap: var(--space-s);
    }
    .navigation-container {
        max-width: 75%;
        margin-inline: auto;
    }
    p, li, img, a {
        color: var(--color-text-muted);
        transition: color var(--transition-normal);
    }
    a:hover, a:focus-within {
        color: var(--color-link-hover);
    }
    a:active {
        color: var(--color-link-active);
    }

    @media only screen and (min-width: 48rem) {
        footer {
            grid-template-columns: 1fr 1fr 1fr;
        }
    }
</style>