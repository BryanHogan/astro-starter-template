---
import BaseLayout from "./BaseLayout.astro";

interface Props {
    title: string;
    description: string;
    canonical?: string;
    ogTitle?: string;
    ogDescription?: string;
    ogImage?: string;
    ogImageAlt?: string;
    ogType?: "website" | "article";
    articlePublished?: Date;
    articleModified?: Date;
    articleTags?: string[];
    robots?: string;
    author?: string;
}
---

<BaseLayout {...Astro.props}>
    <slot name="head" slot="head" />
    <slot />
</BaseLayout>
